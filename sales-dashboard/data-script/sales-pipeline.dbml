// Sales & Customer Lifecycle Dashboard
// Paste into https://dbdiagram.io to render
//
// ⚠️ Path ambiguity note: company_id is denormalized on calls, raw_inputs, and
// subscriptions for query performance. When building the Holistics dataset, only
// register the direct FK to companies from each model — do not also traverse the
// transitive chain (e.g. calls → deals → companies).

// ─── ENUMS ──────────────────────────────────────────────────────────────────────

Enum company_type {
  us          [note: 'Holistics — single internal record']
  prospect    [note: 'Being pursued, pre-deal-won']
  customer    [note: 'Has an active or past subscription']
  competitor  [note: 'Referenced in raw_inputs only, never a deal participant']
}

Enum person_role {
  ae               [note: 'Account Executive — owns and closes deals']
  cs_rep           [note: 'Customer Success — manages post-sale relationship']
  sdr              [note: 'Sales Development Rep — qualifies leads']
  manager          [note: 'Sales or CS manager — team oversight']
  bizops           [note: 'Business Operations — reporting, targets, process']
  champion         [note: 'External — internal advocate at the prospect/customer']
  decision_maker   [note: 'External — approves and signs the deal']
  evaluator        [note: 'External — technical evaluator']
  end_user         [note: 'External — will use the product day-to-day']
}

Enum attendee_role {
  host      [note: 'The rep who led the call — exactly one per call']
  attendee  [note: 'Everyone else on the call']
}

Enum call_phase {
  pre_sale   [note: 'During the sales process, before a deal is won']
  post_sale  [note: 'After the deal is won']
}

Enum call_type {
  discovery    [note: 'First call — understand the prospect context']
  demo         [note: 'Product walkthrough']
  evaluation   [note: 'Deep technical review during trial']
  negotiation  [note: 'Pricing, terms, and contract discussion']
  onboarding   [note: 'First post-sale call to get the customer set up']
  check_in     [note: 'Periodic relationship call with an existing customer']
  renewal      [note: 'Renewing or expanding the subscription']
}

Enum input_type {
  feature_request       [note: 'Customer wants a specific capability we lack']
  requirement           [note: 'Broader need — compliance, integration, architecture']
  competitor_mention    [note: 'A competitor was named or compared']
  concern               [note: 'Friction — pricing, complexity, adoption risk']
  positive_signal       [note: 'Something they praised']
  use_case_description  [note: 'How they intend to use the product']
  trial_feedback        [note: 'Observation from trying the product']
  bug_report            [note: 'Something broken post-sale']
  how_to_question       [note: 'Customer needs help understanding something']
  billing_question      [note: 'Invoice, payment, or plan question']
}

Enum input_source {
  call    [note: 'Captured during a structured call']
  ticket  [note: 'Customer raised via a support channel']
  email   [note: 'Captured from email']
  other
}

Enum input_direction {
  outbound  [note: 'Rep observed or logged it']
  inbound   [note: 'Customer reached out']
}

Enum input_priority {
  low
  medium
  high
  critical
}

Enum input_status {
  open
  in_progress
  waiting_on_customer
  resolved
}

Enum deal_type {
  new_business  [note: 'First-ever deal with this company']
  renewal       [note: 'Continuing an existing subscription after it ends']
  expansion     [note: 'Upgrading to a higher plan or adding seats']
  downgrade     [note: 'Moving to a lower plan']
}

Enum deal_status {
  in_progress  [note: 'Being actively worked']
  won          [note: 'Prospect signed — subscription starts']
  lost         [note: 'Deal closed, never converted']
  ghost        [note: 'Open deal with no activity for 45+ days']
  churned      [note: 'Customer left without renewing']
  renewed      [note: 'Period ended and a new renewal deal was created']
}

Enum deal_stage {
  qualifying   [note: 'Assessing if the prospect is a real fit']
  validating   [note: 'Confirming their needs and our ability to meet them']
  progressing  [note: 'Active evaluation — demos, trial, technical review']
  focus        [note: 'Prospect is seriously considering us']
  negotiating  [note: 'Pricing and terms discussion']
}

Enum lost_reason {
  missing_feature  [note: 'A required capability we do not have']
  pricing          [note: 'Too expensive or unfavorable terms']
  competitor_win   [note: 'Chose a competing product']
  no_budget        [note: 'Budget cut or project deprioritized']
  ghosted          [note: 'Prospect went silent with no decision']
  not_a_fit        [note: 'Use case or profile does not match']
}

Enum billing_cycle {
  monthly
  annual
}

Enum churn_reason {
  voluntary_feature_gap  [note: 'Left because a required feature was not available']
  voluntary_pricing      [note: 'Left due to cost']
  voluntary_competitor   [note: 'Switched to a competing product']
  voluntary_no_usage     [note: 'Not getting value from the product']
  involuntary_payment    [note: 'Payment failure that was not recovered']
  unknown
}

Enum feature_status {
  planned         [note: 'On the roadmap — committed to building']
  in_development  [note: 'Being actively built']
  shipped         [note: 'Released to customers']
  deprecated      [note: 'Was shipped, no longer maintained']
}

Enum improvement_status {
  open        [note: 'Logged by product, not yet planned']
  planned     [note: 'On the roadmap — linked to a feature being built']
  shipped     [note: 'The linked feature shipped — rep should follow up']
  workaround  [note: 'No native solution, but a workaround exists']
  wont_do     [note: 'Product decided not to address this']
  deferred    [note: 'Not now, but not ruled out']
}

// ─── CORE ENTITIES ──────────────────────────────────────────────────────────────

Table companies {
  id             uuid         [pk]
  name           varchar(255) [not null]
  type           company_type [not null]
  industry       varchar(100)
  country        varchar(100)
  employee_count int
  website        varchar(255)
  created_at     timestamp    [not null]

  Note: 'Single table for all organizations — Holistics, prospects, customers, competitors. Internal = type = us.'
}

Table persons {
  id         uuid         [pk]
  company_id uuid         [not null, ref: > companies.id]
  name       varchar(255) [not null]
  email      varchar(255)
  role       person_role  [not null]
  created_at timestamp    [not null]

  Note: 'Single table for all individuals. Internal = persons.company_id → companies.type = us. No is_internal flag needed.'
}

Table calls {
  id           uuid       [pk]
  company_id   uuid       [not null, ref: > companies.id]
  deal_id      uuid       [ref: > deals.id]
  call_date    date       [not null]
  duration_min int
  phase        call_phase [not null]
  type         call_type  [not null]
  notes        text

  Note: 'Attendees in call_attendees (call_id, person_id, role). role = host identifies the rep who led the call.'
}

// Physical junction table — not a conceptual entity
Table call_attendees {
  call_id   uuid          [not null, ref: > calls.id]
  person_id uuid          [not null, ref: > persons.id]
  role      attendee_role [not null]

  indexes {
    (call_id, person_id) [pk]
  }
}

Table raw_inputs {
  id             uuid            [pk]
  company_id     uuid            [not null, ref: > companies.id]
  call_id        uuid            [ref: > calls.id]
  improvement_id uuid            [ref: > improvements.id]
  competitor_id  uuid            [ref: > companies.id]
  input_type     input_type      [not null]
  source         input_source    [not null]
  direction      input_direction [not null]
  is_blocking    boolean         [not null, default: false]
  priority       input_priority
  status         input_status
  description    text
  resolved_at    timestamp
  created_at     timestamp       [not null]

  Note: 'Unified signal table — call signals and support tickets in one table. Differentiated by source. company_id denormalized for direct queries.'
}

Table deals {
  id               uuid        [pk]
  company_id       uuid        [not null, ref: > companies.id]
  owner_id         uuid        [not null, ref: > persons.id]
  deal_type        deal_type   [not null]
  status           deal_status [not null]
  stage            deal_stage
  deal_value_usd   int
  lost_reason      lost_reason
  previous_deal_id uuid        [ref: > deals.id]
  created_at       timestamp   [not null]
  closed_at        timestamp

  Note: 'stage only relevant when status = in_progress. previous_deal_id chains renewals/expansions to the original deal.'
}

// Physical implementation table — not a conceptual entity
Table deal_stage_history {
  id         uuid       [pk]
  deal_id    uuid       [not null, ref: > deals.id]
  stage      deal_stage [not null]
  entered_at timestamp  [not null]
  exited_at  timestamp

  Note: 'exited_at = NULL means currently in this stage. Time-in-stage = COALESCE(exited_at, now()) - entered_at.'
}

Table subscriptions {
  id            uuid          [pk]
  company_id    uuid          [not null, ref: > companies.id]
  deal_id       uuid          [not null, ref: > deals.id]
  plan_name     varchar(100)  [not null]
  mrr_usd       int           [not null]
  billing_cycle billing_cycle [not null]
  started_at    date          [not null]
  ended_at      date
  churn_reason  churn_reason

  Note: 'One active subscription per company at a time. ended_at = NULL means still active. company_id denormalized.'
}

// ─── PRODUCT TAXONOMY ───────────────────────────────────────────────────────────

Table themes {
  id          uuid         [pk]
  name        varchar(255) [not null]
  description text

  Note: 'Top-level strategic area, e.g. Collaboration, Data Governance, Reporting Speed.'
}

Table use_cases {
  id          uuid         [pk]
  theme_id    uuid         [not null, ref: > themes.id]
  name        varchar(255) [not null]
  description text

  Note: 'Customer problem space within a theme — not the solution.'
}

Table features {
  id          uuid           [pk]
  use_case_id uuid           [not null, ref: > use_cases.id]
  name        varchar(255)   [not null]
  description text
  status      feature_status [not null]
  shipped_at  date

  Note: 'What is actually built. shipped_at = NULL means not yet shipped.'
}

Table improvements {
  id              uuid               [pk]
  feature_id      uuid               [ref: > features.id]
  title           varchar(255)       [not null]
  description     text
  status          improvement_status [not null]
  is_blocking     boolean            [not null, default: false]
  raw_input_count int
  created_at      timestamp          [not null]
  updated_at      timestamp          [not null]

  Note: 'Product team synthesis of raw inputs into one customer problem. If feature_id set, use_case/theme reachable via chain. If null, improvement is unclassified.'
}
